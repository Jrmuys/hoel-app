APP_HOST=127.0.0.1
APP_PORT=8080
APP_READ_TIMEOUT=10s
APP_WRITE_TIMEOUT=15s
APP_SHUTDOWN_TIMEOUT=10s
APP_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SQLITE_PATH=./hoel.db
MIGRATIONS_DIR=./migrations
OUTBOUND_HTTP_TIMEOUT=8s
OUTBOUND_RETRY_COUNT=2
OUTBOUND_RETRY_BACKOFF=300ms
PGHST_ENDPOINT=https://pgh.st/locate/...
PGHST_POLL_INTERVAL=12h
